    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "prisma": "^5.0.0",
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2",
    "@types/bcryptjs": "^2.4.6"
  },
  "prisma": {
    "schema": "./prisma/schema.prisma",
    "seed": "ts-node --transpile-only prisma/seed.ts"
  }
