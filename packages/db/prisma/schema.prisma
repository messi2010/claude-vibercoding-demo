datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
}

enum AuthProvider {
  LOCAL
  GOOGLE
  FACEBOOK
}

enum StoryStatus {
  ONGOING
  COMPLETED
}

model User {
  id              String            @id @default(uuid())
  email           String            @unique
  name            String?
  avatar          String?
  dob             DateTime?
  password        String?
  provider        AuthProvider      @default(LOCAL)
  isAgeVerified   Boolean           @default(false)
  role            Role              @default(USER)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  readingProgress ReadingProgress[]
}

model Story {
  id              String            @id @default(uuid())
  title           String
  slug            String            @unique
  description     String?
  coverImage      String?
  status          StoryStatus       @default(ONGOING)
  isAdult         Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  genres          StoryGenre[]
  chapters        Chapter[]
  readingProgress ReadingProgress[]
}

model StoryGenre {
  storyId String
  genre   String
  story   Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@id([storyId, genre])
  @@index([genre])
}

model Chapter {
  id              String            @id @default(uuid())
  storyId         String
  number          Int
  title           String?
  createdAt       DateTime          @default(now())
  story           Story             @relation(fields: [storyId], references: [id], onDelete: Cascade)
  pages           Page[]
  readingProgress ReadingProgress[]

  @@unique([storyId, number])
  @@index([storyId])
}

model Page {
  id        String  @id @default(uuid())
  chapterId String
  number    Int
  content   String
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, number])
  @@index([chapterId])
}

model ReadingProgress {
  id         String   @id @default(uuid())
  userId     String
  storyId    String
  chapterId  String
  pageNumber Int
  updatedAt  DateTime @default(now()) @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  story      Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  chapter    Chapter  @relation(fields: [chapterId], references: [id])

  @@unique([userId, storyId])
  @@index([userId])
  @@index([chapterId])
}
